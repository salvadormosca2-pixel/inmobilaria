# Copiá este archivo a .env (cp .env.example .env) y completá los valores.
# El .env real está gitignoreado: NO lo subas.

# Contraseña de la Postgres interna de n8n (inventá una larga).
POSTGRES_PASSWORD=cambiame-por-una-clave-larga

# Clave de cifrado de credenciales de n8n. Generá una con:
#   openssl rand -hex 32     (o)     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: si la cambiás después, n8n pierde acceso a las credenciales guardadas.
N8N_ENCRYPTION_KEY=pega-aca-64-hex-generados

# Cómo se accede a n8n. En local basta con lo de abajo.
N8N_HOST=localhost
N8N_PROTOCOL=http

# URL PÚBLICA del webhook (la que va a llamar Chatwoot). En local, n8n no es
# accesible desde internet: usá un túnel (Cloudflare Tunnel, ngrok) o un dominio.
# Ej. producción:  https://n8n.josegreco.com.ar
WEBHOOK_URL=http://localhost:5678
